# PROMEOS Backend Configuration Example
# Copy this file to .env and fill in your values

# ============================================================================
# AI Configuration (Optional - AI agents run in stub mode if not configured)
# ============================================================================

# AI API Key for AI agents (regops_explainer, regops_recommender, data_quality, etc.)
# If not set, agents return stub responses with [AI Stub Mode] prefix
AI_API_KEY=your_anthropic_api_key_here

# AI Model to use (default: claude-sonnet-4-5-20250929)
AI_MODEL=claude-sonnet-4-5-20250929

# ============================================================================
# External Data Connectors (Optional)
# ============================================================================

# Météo-France API (required for meteofrance_connector)
# Register at: https://portail-api.meteofrance.fr/
METEOFRANCE_API_KEY=your_meteofrance_api_key_here

# Enedis DataConnect OAuth (required for enedis_dataconnect_connector)
# Register at: https://datahub-enedis.fr/data-connect/
ENEDIS_CLIENT_ID=your_enedis_client_id_here
ENEDIS_CLIENT_SECRET=your_enedis_client_secret_here

# Enedis SGE Flux Ingestion (required for SGE pipeline — SF4)
# Absolute path to the directory containing encrypted .zip flux files
ENEDIS_FLUX_DIR=/absolute/path/to/flux_enedis

# GRDF ADICT OAuth (required for grdf_adict_connector)
# Register at: https://sites.grdf.fr/web/adict
GRDF_CLIENT_ID=your_grdf_client_id_here
GRDF_CLIENT_SECRET=your_grdf_client_secret_here

# ============================================================================
# Security / JWT
# ============================================================================

# JWT secret for API token signing (MUST change in production)
PROMEOS_JWT_SECRET=change-me-in-production

# ============================================================================
# Public Connectors (No credentials needed - already functional)
# ============================================================================

# RTE eCO2mix: Grid CO2 intensity data
# Public API: https://odre.opendatasoft.com/

# PVGIS: Solar production estimates
# Public API: https://re.jrc.ec.europa.eu/api/

# ============================================================================
# Database (SQLite - no config needed for dev)
# ============================================================================

# SQLite (default, dev local — no config needed)
# DATABASE_URL=sqlite:///./data/promeos.db

# PostgreSQL (pilot / production)
# DATABASE_URL=postgresql://promeos:password@localhost:5432/promeos
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10

# ============================================================================
# Server Configuration
# ============================================================================

# Backend host and port (defaults in main.py)
# HOST=127.0.0.1
# PORT=8001

# ============================================================================
# Regulatory Watchers (No credentials needed - RSS feeds are public)
# ============================================================================

# Légifrance Flux RSS: https://www.legifrance.gouv.fr/
# CRE Publications: https://www.cre.fr/
# RTE News: https://www.rte-france.com/

# ============================================================================
# Feature Flags
# ============================================================================

# Enable demo mode by default (adds demo badges, CORS=*, hides sensitive data)
# DEMO_MODE=true

# CORS origins (comma-separated, only used when DEMO_MODE=false)
# PROMEOS_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================================================
# Security Notes
# ============================================================================

# 1. NEVER commit .env to version control
# 2. Keep API keys secure and rotate them regularly
# 3. Use environment-specific .env files (.env.production, .env.staging)
# 4. Limit API key permissions to minimum required scope
# 5. Monitor API usage for anomalies

# ============================================================================
# Getting Started
# ============================================================================

# 1. Copy this file: cp .env.example .env
# 2. Fill in required values (AI_API_KEY if you want AI agents)
# 3. Run backend: cd backend && python main.py
# 4. Access API docs: http://127.0.0.1:8001/docs
# 5. Test connectors: GET /api/connectors/list
# 6. Test watchers: GET /api/watchers/list
# 7. Test AI agents: GET /api/ai/site/1/explain (stub mode if no key)

# ============================================================================
# Email Provider (Sprint α-push Phase 2.B — digest matinal Marie 7h45)
# ============================================================================
# Provider abstraction `backend/services/email_provider.py`. Q1 audit Phase
# 0.bis arbitré : Brevo (FR, serveurs UE → RGPD natif, pas de SCC UE-US).
# Architecturalement extensible (Scaleway TEM / Tipimail / AWS SES eu-west-1).
#
# Provider à utiliser. Default = brevo.
EMAIL_PROVIDER=brevo
#
# Brevo API key (transactional email). Obtenir sur https://app.brevo.com/
# Settings -> SMTP & API -> API Keys -> Generate new key (v3 transactional).
# Format : xkeysib-<long_token>
BREVO_API_KEY=your_brevo_api_key_here
#
# From address utilisee par tous les emails sortants (digest, etc.).
# Doit etre validee cote Brevo (Settings -> Senders & IP).
EMAIL_FROM=noreply@promeos.io
EMAIL_FROM_NAME=PROMEOS

# ============================================================================
# Agent SDK Configuration (Claude Agent SDK — orchestration dev/CI)
# ============================================================================
# Used by `backend/orchestration/` (QA Guardian, audits, sprints, CI/CD).
# This is SEPARATE from `backend/ai_layer/` which uses AI_API_KEY directly.
#
# The SDK reads ANTHROPIC_API_KEY (NOT AI_API_KEY). If both point to the
# same Anthropic key, duplicate the value in both variables.
#
# ANTHROPIC_API_KEY=sk-ant-...
# AGENT_SDK_MODEL=sonnet           # alias: sonnet | opus | haiku
# AGENT_SDK_FALLBACK=haiku
# AGENT_SDK_MAX_TURNS=15

# ============================================================================
# PROMEOS V4 Centre d'Action — Mois 2 backend (ADR-027 + ADR-029)
# ============================================================================
# Variables introduites par Sprint M2-1 Foundation infra (cf. L9 §2).
# Cardinaux Amine référencés dans chaque section.

# ─── JWT fresh token (ADR-027 IS5 + ADR-028 IL3) ────────────────────────────
# Réouverture admin + actions sensibles (kind_corrected, delete_user_data) exigent
# un token <5min (300s). Force re-authentification utilisateur récente.
JWT_ADMIN_FRESH_TOKEN_MAX_AGE_SECONDS=300

# ─── Evidence storage (ADR-029 IE1 + Q40-D + Q45-B) ──────────────────────────
# Storage abstrait : "filesystem" Mois 2-6 POC · "s3" V4.1+ via factory get_storage_backend().
EVIDENCE_STORAGE_BACKEND=filesystem
# Path filesystem (gitignored — IE1 + IS10 + I9 cardinaux).
EVIDENCE_FS_ROOT=/data/promeos/evidences
# Q45-B : 10 MB max par evidence (CHECK constraint DB + check explicite endpoint).
EVIDENCE_MAX_SIZE_BYTES=10485760

# ─── Retention purge mensuelle (ADR-029 IE5 — triple garde-fou) ──────────────
# Garde-fou 1 : feature flag global (OFF Mois 2-3, activation Mois 4 J-7 dry-run).
RETENTION_PURGE_ENABLED=False
# Garde-fou 2 : dry-run obligatoire en première activation (counts only, no DELETE).
RETENTION_PURGE_DRY_RUN_FIRST=True
# Garde-fou 3 : trace security_audit_log avec correlation_id (cf. backend/maintenance/).

# ─── Logging structuré (ADR-027 IS7-IS9) ─────────────────────────────────────
# IS7 logs sanitisés (pas de body / token / query string sensible).
# IS8 IP anonymisée /24 IPv4 + /48 IPv6 (anonymize_ip helper).
# IS9 correlation_id propagé dans tous events.
LOG_LEVEL=INFO
LOG_FORMAT=json

# ─── Feature flag V4 (cutover Mois 4 — Q13-B) ────────────────────────────────
# OFF Mois 2-3 (coexistence legacy + V4). Activation J0 Mois 4 cutover.
FEATURE_FLAG_V4_ENABLED=False
