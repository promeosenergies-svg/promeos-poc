# PROMEOS Backend Configuration Example
# Copy this file to .env and fill in your values

# ============================================================================
# AI Configuration (Optional - AI agents run in stub mode if not configured)
# ============================================================================

# AI API Key for AI agents (regops_explainer, regops_recommender, data_quality, etc.)
# If not set, agents return stub responses with [AI Stub Mode] prefix
AI_API_KEY=your_anthropic_api_key_here

# AI Model to use (default: claude-sonnet-4-5-20250929)
AI_MODEL=claude-sonnet-4-5-20250929

# ============================================================================
# External Data Connectors (Optional)
# ============================================================================

# Météo-France API (required for meteofrance_connector)
# Register at: https://portail-api.meteofrance.fr/
METEOFRANCE_API_KEY=your_meteofrance_api_key_here

# Enedis DataConnect OAuth (required for enedis_dataconnect_connector)
# Register at: https://datahub-enedis.fr/data-connect/
ENEDIS_CLIENT_ID=your_enedis_client_id_here
ENEDIS_CLIENT_SECRET=your_enedis_client_secret_here

# ============================================================================
# Public Connectors (No credentials needed - already functional)
# ============================================================================

# RTE eCO2mix: Grid CO2 intensity data
# Public API: https://odre.opendatasoft.com/

# PVGIS: Solar production estimates
# Public API: https://re.jrc.ec.europa.eu/api/

# ============================================================================
# Database (SQLite - no config needed for dev)
# ============================================================================

# Database path defaults to: backend/promeos.db
# DATABASE_URL=sqlite:///./promeos.db

# ============================================================================
# Server Configuration
# ============================================================================

# Backend host and port (defaults in main.py)
# HOST=127.0.0.1
# PORT=8001

# ============================================================================
# Regulatory Watchers (No credentials needed - RSS feeds are public)
# ============================================================================

# Légifrance Flux RSS: https://www.legifrance.gouv.fr/
# CRE Publications: https://www.cre.fr/
# RTE News: https://www.rte-france.com/

# ============================================================================
# Feature Flags
# ============================================================================

# Enable demo mode by default (adds demo badges, hides sensitive data)
# DEMO_MODE=true

# ============================================================================
# Security Notes
# ============================================================================

# 1. NEVER commit .env to version control
# 2. Keep API keys secure and rotate them regularly
# 3. Use environment-specific .env files (.env.production, .env.staging)
# 4. Limit API key permissions to minimum required scope
# 5. Monitor API usage for anomalies

# ============================================================================
# Getting Started
# ============================================================================

# 1. Copy this file: cp .env.example .env
# 2. Fill in required values (AI_API_KEY if you want AI agents)
# 3. Run backend: cd backend && python main.py
# 4. Access API docs: http://127.0.0.1:8001/docs
# 5. Test connectors: GET /api/connectors/list
# 6. Test watchers: GET /api/watchers/list
# 7. Test AI agents: GET /api/ai/site/1/explain (stub mode if no key)
