{
  "name": "promeos-frontend",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:check": "vite build && node scripts/check-bundle-size.js",
    "preview": "vite preview",
    "lint": "eslint src --ext js,jsx --max-warnings=40",
    "format": "prettier --write 'src/**/*.{js,jsx,css,json}'",
    "format:check": "prettier --check 'src/**/*.{js,jsx,css,json}'",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.13.18",
    "axios": "^1.13.4",
    "lucide-react": "^0.563.0",
    "maplibre-gl": "^5.19.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.30.3",
    "recharts": "^3.7.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.1.1",
    "tailwindcss": "^4.1.18",
    "vite": "^5.0.7",
    "vitest": "^4.0.18"
  }
}
