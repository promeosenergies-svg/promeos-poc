# Variables d'environnement Vite — Frontend PROMEOS
# Copier vers .env et adapter (jamais committer .env)

# API backend
VITE_API_URL=/api

# Observabilité (optionnel)
VITE_SENTRY_DSN=

# Feature flags (M2-5+)
# Active la nouvelle interface Centre d'Action V4 (route /action-center-v4).
# OFF par défaut — doctrine M2-5 (cf. M2-5_FRONTEND_PLAN.md §13.5) : legacy
# 100 % intact tant que le flag est OFF.
# Activation en dev local : copier ce fichier vers frontend/.env, passer la
# valeur à `true`, puis relancer `npm run dev`. Côté backend, exporter aussi
# `PROMEOS_DEMO_MODE=true` pour surfacer le bouton « Connexion démo HELIOS »
# sur /login (seule voie d'accès au pilote V4).
VITE_FEATURE_ACTION_CENTER_V4=false
