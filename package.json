{
  "name": "promeos-poc",
  "version": "0.1.0",
  "description": "POC PROMEOS - Gestion multi-sites énergétique intelligente",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "install-all": "npm install && cd frontend && npm install && cd ..",
    "setup": "bash scripts/setup.sh",
    "dev": "bash scripts/dev.sh",
    "dev:full": "concurrently -n BE,FE -c blue,green \"py -3.14 backend/main.py\" \"wait-on http://127.0.0.1:8001/api/health && npm run dev --prefix frontend\"",
    "backend": "cd backend && python main.py",
    "frontend": "npm run dev --prefix frontend",
    "build": "npm run build --prefix frontend",
    "lint": "npm run lint --prefix frontend",
    "format": "npm run format --prefix frontend",
    "prepare": "husky"
  },
  "devDependencies": {
    "axe-core": "^4.11.2",
    "concurrently": "^9.1.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "playwright": "^1.59.1",
    "vitest-axe": "^0.1.0",
    "wait-on": "^8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/promeosenergies-svg/promeos-poc.git"
  },
  "keywords": [
    "energy-management",
    "multi-site",
    "decarbonation",
    "fastapi",
    "react"
  ],
  "author": "PROMEOS Énergies",
  "license": "MIT"
}
