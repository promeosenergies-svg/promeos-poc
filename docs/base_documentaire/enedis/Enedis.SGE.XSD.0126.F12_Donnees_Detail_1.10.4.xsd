				</xsd:simpleType>
			</xsd:element>
			<xsd:element name="Nb_Sous_Lot">
				<xsd:simpleType>
					<xsd:restriction base="xsd:positiveInteger">
						<xsd:totalDigits value="12"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:element>
			<xsd:element name="Sous_Total_HT">
				<xsd:simpleType>
					<xsd:restriction base="xsd:decimal">
						<xsd:totalDigits value="18"/>
						<xsd:fractionDigits value="2"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="PS_Poste_Horosaisonnier" mixed="false">
		<xsd:sequence>
			<xsd:element name="Nom_Poste_Horosaisonnier">
				<xsd:simpleType>
					<xsd:restriction base="xsd:string">
						<xsd:enumeration value="Pointe"/>
						<xsd:enumeration value="HPH"/>
						<xsd:enumeration value="HCH"/>
						<xsd:enumeration value="HPE"/>
						<xsd:enumeration value="HCE"/>
						<xsd:enumeration value="HCDemiSaison"/>
						<xsd:enumeration value="HPDemiSaison"/>
						<xsd:enumeration value="JA"/>
						<xsd:enumeration value="HP"/>
						<xsd:enumeration value="HC"/>
						<xsd:enumeration value="PM"/>
					</xsd:restriction>
				</xsd:simpleType>
