			<xsd:element name="Num_Sous_Lot">
				<xsd:simpleType>
					<xsd:restriction base="xsd:string">
						<xsd:maxLength value="12"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:element>
			<xsd:element name="Type_Facturation">
				<xsd:simpleType>
					<xsd:restriction base="xsd:string">
						<xsd:enumeration value="EVNT"/>
						<xsd:enumeration value="CYCL"/>
						<xsd:enumeration value="RECT"/>
						<xsd:enumeration value="ANNUL"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:element>
			<xsd:element name="Id_PRM" minOccurs="0">
				<xsd:simpleType>
					<xsd:restriction base="xsd:string">
