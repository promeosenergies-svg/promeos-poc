                                    "libelleCalendrier": {
                                      "type": "string"
                                    },
									"libelleGrille": {
                                      "type": "string"
									},
                                    "classeTemporelle": {
                                      "type": "array",
                                      "items": [
                                        {
                                          "type": "object",
                                          "properties": {
                                            "idClasseTemporelle": {
                                              "type": "string"
                                            },
                                            "libelleClasseTemporelle": {
                                              "type": "string"
                                            },
											"codeCadran": {
                                              "type": "string"
                                            },
                                            "valeur": {
                                              "type": "array",
                                              "items": [
                                                {
                                                  "type": "object",
                                                  "properties": {
                                                    "d": {
                                                      "type": "string"
                                                    },
                                                    "v": {
                                                      "type": "integer"
                                                    },
                                                    "iv": {
                                                      "type": ["integer","null"]
                                                    }
                                                  },
                                                  "required": [
                                                    "d",
                                                    "v",
                                                    "iv"
                                                  ]
                                                }
                                              ]
                                            }
                                          },
                                          "required": [
                                            "valeur"
                                          ]
                                        }
                                      ]
                                    }
                                  },
                                  "required": [
                                    "idCalendrier",
                                    "libelleCalendrier",
									                  "libelleGrille",
                                    "classeTemporelle"
                                  ]
                                }
                              ]
                            },
                            "cadranTotalisateur": {
                              "type": "object",
                              "properties": {
                                "codeCadran": {
                                  "type": "string"
                                },
                                "valeur": {
                                  "type": "array",
                                  "items": [
                                    {
                                      "type": "object",
                                      "properties": {
                                        "d": {
                                          "type": "string"
                                        },
                                        "v": {
                                          "type": "integer"
                                        },
                                        "iv": {
                                          "type": ["integer","null"]
                                        }
