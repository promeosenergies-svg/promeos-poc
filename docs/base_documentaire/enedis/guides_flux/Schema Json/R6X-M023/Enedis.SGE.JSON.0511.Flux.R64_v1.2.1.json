                        {
                          "type": "object",
                          "properties": {
                            "grandeurMetier": {
                              "type": "string"
                            },
                            "grandeurPhysique": {
                              "type": "string"
                            },
                            "unite": {
                              "type": "string"
                            },
                            "calendrier": {
                              "type": "array",
                              "items": [
                                {
                                  "type": "object",
                                  "properties": {
                                    "idCalendrier": {
                                      "type": "string"
