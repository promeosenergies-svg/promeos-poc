                            "grandeurPhysique",
                            "unite"
                          ]
                        }
                      ]
                    }
                  },
                  "required": [
                    "etapeMetier",
                    "contexteReleve",
                    "typeReleve",
                    "grandeur"
                  ]
                }
              ]
            }
          },
          "required": [
            "idPrm",
            "periode",
            "contexte"
          ]
        }
      ]
