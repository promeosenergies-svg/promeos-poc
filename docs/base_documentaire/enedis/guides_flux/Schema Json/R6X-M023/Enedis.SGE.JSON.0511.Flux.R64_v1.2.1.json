{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "type": "object",
  "properties": {
    "header": {
      "type": "object",
      "properties": {
        "siDemandeur": {
          "type": "string"
        },
        "typeDestinataire": {
          "type": "string"
        },
        "idDestinataire": {
          "type": "string"
        },
        "codeFlux": {
          "type": "string"
        },
        "idDemande": {
          "type": "string"
        },
        "modePublication": {
          "type": "string"
        },
        "idCanalContact": {
          "type": "string"
        },
        "format": {
          "type": "string"
        },
		"publicationCrp":{
			"type":"string"
		}
      },
      "required": [
        "siDemandeur",
        "typeDestinataire",
        "idDestinataire",
        "codeFlux",
        "idDemande",
        "modePublication",
        "idCanalContact",
        "format"
      ]
    },
    "mesures": {
      "type": "array",
      "items": [
        {
          "type": "object",
          "properties": {
            "idPrm": {
              "type": "string"
            },
            "periode": {
              "type": "object",
