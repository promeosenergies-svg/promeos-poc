# Backend Configuration
DATABASE_URL=sqlite:///./data/promeos.db
DEBUG=True
API_HOST=127.0.0.1
API_PORT=8001

# Frontend
FRONTEND_URL=http://localhost:5173

# Seed Data Configuration
SEED_NB_SITES=120
SEED_NB_ORGANIZATIONS=1
SEED_START_YEAR=2020

# Security (à changer en production!)
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# External Data Connectors
# ENTSO-E Transparency Platform (required for market data connector)
# Register at: https://transparency.entsoe.eu/
# Then email transparency@entsoe.eu with subject "Restful API access"
ENTSOE_API_KEY=your_entsoe_api_key_here

# Enedis DataConnect OAuth2 (required for enedis_dataconnect_connector)
ENEDIS_CLIENT_ID=your_enedis_client_id_here
ENEDIS_CLIENT_SECRET=your_enedis_client_secret_here

# Enedis SGE Flux Ingestion (required for SGE pipeline — SF4)
# Absolute path to the directory containing encrypted .zip flux files
ENEDIS_FLUX_DIR=/absolute/path/to/flux_enedis

# GRDF ADICT OAuth2 (required for grdf_adict_connector)
GRDF_CLIENT_ID=your_grdf_client_id_here
GRDF_CLIENT_SECRET=your_grdf_client_secret_here

# JWT secret for API token signing (MUST change in production)
PROMEOS_JWT_SECRET=change-me-in-production

# ════════════════════════════════════════════════════════════════════
# Authentification — runbook pilote / production
# ════════════════════════════════════════════════════════════════════
#
# Deux flags contrôlent l'authentification du backend :
#
# PROMEOS_AUTH_ENABLED  PROMEOS_DEMO_MODE   Comportement
# ──────────────────────────────────────────────────────────────────
# true                  false              ✅ PRODUCTION / PILOT — JWT
#                                            obligatoire, refus 401 sans
#                                            token. Conforme ADR-027.
# true                  true               ⚠️ DEMO sécurisée — JWT
#                                            obligatoire ; tokens forgés
#                                            rejetés (anti-bypass).
# false                 true               ⚠️ DEMO LOCALE uniquement —
#                                            aucun token requis, accès
#                                            sans authentification à
#                                            TOUS les endpoints write
#                                            (PATCH /lifecycle, POST
#                                            /evidences, PATCH /assign…).
#                                            NE JAMAIS activer en pilot.
# false                 false              ❌ Configuration interdite
#                                            (incohérente).
#
# AVANT MISE EN PRODUCTION (cf. PROMEOS-SEC-2026-001 — audit
# security-auditor) :
#   1. PROMEOS_AUTH_ENABLED=true
#   2. PROMEOS_DEMO_MODE=false
#   3. PROMEOS_JWT_SECRET ≠ valeur par défaut (rotation après chaque
#      déploiement, conservée hors Git)
#   4. ALGORITHM=HS256 (ou RS256 si infra à clé publique disponible)
#
# Valeurs locales DEMO (dev only) :
PROMEOS_AUTH_ENABLED=false
PROMEOS_DEMO_MODE=true
