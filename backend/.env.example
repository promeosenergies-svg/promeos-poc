# Backend Configuration
DATABASE_URL=sqlite:///./data/promeos.db
DEBUG=True
API_HOST=127.0.0.1
API_PORT=8001

# Frontend
FRONTEND_URL=http://localhost:5173

# Seed Data Configuration
SEED_NB_SITES=120
SEED_NB_ORGANIZATIONS=1
SEED_START_YEAR=2020

# Security (à changer en production!)
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# External Data Connectors
# ENTSO-E Transparency Platform (required for market data connector)
# Register at: https://transparency.entsoe.eu/
# Then email transparency@entsoe.eu with subject "Restful API access"
ENTSOE_API_KEY=your_entsoe_api_key_here
